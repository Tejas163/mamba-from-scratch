   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Comparison with Attention"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title ⚖️ Compare Mamba vs Attention\n",
    "\n",
    "class SimpleAttention(nn.Module):\n",
    "    \"\"\"Simple multi-head attention for comparison\"\"\"\n",
    "    \n",
    "    def __init__(self, d_model: int, n_heads: int = 8, dropout: float = 0.0):\n",
    "        super().__init__()\n",
    "        self.n_heads = n_heads\n",
    "        self.d_head = d_model // n_heads\n",
    "        \n",
    "        self.qkv = nn.Linear(d_model, 3 * d_model)\n",
    "        self.out_proj = nn.Linear(d_model, d_model)\n",
    "        self.dropout = nn.Dropout(dropout)\n",
    "        \n",
    "        self.norm = nn.LayerNorm(d_model)\n",
    "    \n",
    "    def forward(self, x: torch.Tensor) -> torch.Tensor:\n",
    "        x_norm = self.norm(x)\n",
    "        \n",
    "        B, L, D = x_norm.shape\n",
    "        \n",
    "        # QKV projection\n",
    "        qkv = self.qkv(x_norm)\n",
    "        q, k, v = qkv.split(D, dim=-1)\n",
    "        \n",
    "        # Reshape for multi-head\n",
    "        q = q.view(B, L, self.n_heads, self.d_head).transpose(1, 2)\n",
    "        k = k.view(B, L, self.n_heads, self.d_head).transpose(1, 2)\n",
    "        v = v.view(B, L, self.n_heads, self.d_head).transpose(1, 2)\n",
    "        \n",
    "        # Attention\n",
    "        scores = torch.matmul(q, k.transpose(-2, -1)) / (self.d_head ** 0.5)\n",
    "        attn = F.softmax(scores, dim=-1)\n",
    "        attn = self.dropout(attn)\n",
    "        \n",
    "        # Apply attention\n",
    "        out = torch.matmul(attn, v)\n",
    "        out = out.transpose(1, 2).contiguous().view(B, L, D)\n",
    "        \n",
    "        out = self.out_proj(out)\n",
    "        return out + x\n",
    "\n",
    "\n",
    "# Compare parameter count\n",
    "d_model = 512\n",
    "n_heads = 8\n",
    "d_state = 128\n",
    "\n",
    "mamba = MambaBlock(d_model=d_model, d_state=d_state, expand_factor=2)\n",
    "attention = SimpleAttention(d_model=d_model, n_heads=n_heads)\n",
    "\n",
    "mamba_params = sum(p.numel() for p in mamba.parameters())\n",
    "attention_params = sum(p.numel() for p in attention.parameters())\n",
    "\n",
    "print(\"=\" * 50)\n",
    "print(\"Parameter Comparison\")\n",
    "print(\"=\" * 50)\n",
    "print(f\"Mamba Block:   {mamba_params:,} params\")\n",
    "print(f\"Attention:     {attention_params:,} params\")\n",
    "print(f\"Ratio:         {mamba_params/attention_params:.2f}x\")\n",
    "\n",
    "# Compare computation\n",
    "import time\n",
    "\n",
    "seq_lens = [32, 64, 128, 256, 512]\n",
    "mamba_times = []\n",
    "attention_times = []\n",
    "\n",
    "mamba = mamba.to(device)\n",
    "attention = attention.to(device)\n",
    "\n",
    "print(\"\\n\" + \"=\" * 50)\n",
    "print(\"Speed Comparison (ms)\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "for seq_len in seq_lens:\n",
    "    x = torch.randn(4, seq_len, d_model).to(device)\n",
    "    \n",
    "    # Warm up\n",
    "    with torch.no_grad():\n",
    "        _ = mamba(x)\n",
    "        _ = attention(x)\n",
    "    \n",
    "    torch.cuda.synchronize() if device.type == 'cuda' else None\n",
    "    \n",
    "    # Time Mamba\n",
    "    start = time.perf_counter()\n",
    "    with torch.no_grad():\n",
    "        for _ in range(10):\n",
    "            y_mamba = mamba(x)\n",
    "    torch.cuda.synchronize() if device.type == 'cuda' else None\n",
    "    t_mamba = (time.perf_counter() - start) / 10 * 1000\n",
    "    \n",
    "    # Time Attention\n",
    "    start = time.perf_counter()\n",
    "    with torch.no_grad():\n",
    "        for _ in range(10):\n",
    "            y_attn = attention(x)\n",
    "    torch.cuda.synchronize() if device.type == 'cuda' else None\n",
    "    t_attn = (time.perf_counter() - start) / 10 * 1000\n",
    "    \n",
    "    mamba_times.append(t_mamba)\n",
    "attention_times.append(t_attn)\n",
    "    \n",
    "    print(f\"Seq {seq_len:4d}: Mamba={t_mamba:7.2f}ms, Attention={t_attn:7.2f}ms, Speedup={t_attn/t_mamba:.2f}x\")\n",
    "\n",
    "# Plot\n",
    "fig, axes = plt.subplots(1, 2, figsize=(12, 4))\n",
    "\n",
    "# Parameters\n",
    "axes[0].bar(['Mamba', 'Attention'], [mamba_params, attention_params])\n",
    "axes[0].set_ylabel('Parameters')\n",
    "axes[0].set_title('Parameter Count')\n",
    "\n",
    "# Speed\n",
    "axes[1].plot(seq_lens, mamba_times, 'o-', label='Mamba', linewidth=2)\n",
    "axes[1].plot(seq_lens, attention_times, 's-', label='Attention', linewidth=2)\n",
    "axes[1].set_xlabel('Sequence Length')\n",
    "axes[1].set_ylabel('Time (ms)')\n",
    "axes[1].set_title('Inference Speed')\n",
    "axes[1].legend()\n",
    "axes[1].grid(True)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('mamba_vs_attention.png', dpi=150)\n",
    "plt.show()\n",
    "\n",
    "print(\"\\n✅ Mamba is typically faster at longer sequences due to O(N) vs O(N²)!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Full Mamba Layer (Stacked Blocks)"
   ]
  },
  {
   "cell_type": "code",
<parameter name="execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 🏗️ Mamba Layer (Multiple Blocks)\n",
    "\n",
    "class MambaLayer(nn.Module):\n",
    "    \"\"\"\n",
    "    Complete Mamba Layer with multiple blocks.\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(\n",
    "        self,\n",
    "        d_model: int,\n",
    "        n_layers: int = 4,\n",
    "        d_state: int = 128,\n",
    "        expand_factor: int = 2,\n",
    "    ):\n",
    "        super().__init__()\n",
    "        \n",
    "        self.layers = nn.ModuleList([\n",
    "            MambaBlock(\n",
    "                d_model=d_model,\n",
    "                d_state=d_state,\n",
    "                expand_factor=expand_factor,\n",
    "            )\n",
    "            for _ in range(n_layers)\n",
    "        ])\n",
    "        \n",
    "        self.norm = nn.LayerNorm(d_model)\n",
    "    \n",
    "    def forward(self, x: torch.Tensor) -> torch.Tensor:\n",
    "        \"\"\"\n",
    "        Args:\n",
    "            x: (batch, seq_len, d_model)\n",
    "        Returns:\n",
    "            y: (batch, seq_len, d_model)\n",
    "        \"\"\"\n",
    "        for layer in self.layers:\n",
    "            x = layer(x)\n",
    "        return self.norm(x)\n",
    "\n",
    "\n",
    "# Test\n",
    "print(\"Testing Mamba Layer...\")\n",
    "layer = MambaLayer(d_model=256, n_layers=4, d_state=128).to(device)\n",
    "x = torch.randn(2, 32, 256).to(device)\n",
    "y = layer(x)\n",
    "print(f\"Input shape: {x.shape}\")\n",
    "print(f\"Output shape: {y.shape}\")\n",
    "\n",
    "n_params = sum(p.numel() for p in layer.parameters())\n",
    "print(f\"Total parameters: {n_params:,}\")"
   ]
  },
