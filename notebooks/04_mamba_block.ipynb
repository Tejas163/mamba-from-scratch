   "source": [
    "# 📚 Build Mamba SSM from Scratch - Part 4: Full Mamba Block\n",
    "\n",
    "---\n",
    "\n",
    "**Colab Ready**: This notebook runs on Google Colab with GPU support!\n",
    "\n",
    "**Objectives**:\n",
    "1. Understand all components of the Mamba block\n",
    "2. Add gating, normalization, and residual connections\n",
    "3. Implement the modern architecture tricks\n",
    "4. Compare with transformer-like attention\n",
    "\n",
    "---\n",
    "\n",
    "## 1. The Full Mamba Block Architecture\n",
    "\n",
    "The Mamba block consists of:\n",
    "\n",
    "```\n",
    "Input x\n",
    "    │\n",
    "    ▼\n",
    "┌─────────────────────┐\n",
    "│  LayerNorm          │  (pre-norm for stability)\n",
    "└─────────────────────┘\n",
    "    │\n",
    "    ▼\n",
    "┌─────────────────────┐\n",
    "│  Linear (expand)     │  d_model → d_inner\n",
    "└─────────────────────┘\n",
    "    │\n",
    "    ▼\n",
    "┌─────────────────────┐\n",
    "│  SiLU (Swish)       │  Gating activation\n",
    "└─────────────────────┘\n",
    "    │\n",
    "    ▼\n",
    "┌─────────────────────┐\n",
    "│  Selective SSM      │  (core Mamba component)\n",
    "└─────────────────────┘\n",
    "    │\n",
    "    ▼\n",
    "┌─────────────────────┐\n",
    "│  Linear (contract)  │  d_inner → d_model\n",
    "└─────────────────────┘\n",
    "    │\n",
    "    ▼\n",
    "┌─────────────────────┐\n",
    "│  Dropout            │  (optional)\n",
    "└─────────────────────┘\n",
    "    │\n",
    "    ▼\n",
    "Output + Residual\n",
    "```"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Key Components Explained\n",
    "\n",
    "### 2.1 Gating (SiLU Activation)\n",
    "Mamba uses the **SiLU (Sigmoid Linear Unit)** / Swish activation:\n",
    "\n",
    "$$\n",
    "\\text{SiLU}(x) = x \\cdot \\sigma(x) = \\frac{x}{1 + e^{-x}}\n",
    "$$\n",
    "\n",
    "This provides a **gating** effect - values can be smoothly suppressed or amplified.\n",
    "\n",
    "### 2.2 Expansion Factor\n",
    "The inner dimension is typically $2 \\times$ the model dimension:\n",
    "\n",
    "$d_{\\text{inner}} = \\text{expand_factor} \\times d_{\\text{model}}$"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 2.3 Residual Connection\n",
    "\n",
    "Standard residual connection:\n",
    "\n",
    "$$\n",
    "y = \\text{MambaBlock}(x) + x\n",
    "$$\n",
    "\n",
    "This helps with gradient flow and training stability."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 2.4 Pre-Norm vs Post-Norm\n",
    "\n",
    "Mamba uses **Pre-Norm** (normalize before the layer):\n",
    "\n",
    "$$\n",
    "y = \\text{Layer}(\\text{Norm}(x)) + x\n",
    "$$\n",
    "\n",
    "vs Post-Norm:\n",
    "\n",
    "$$\n",
    "y = \\text{Norm}(\\text{Layer}(x) + x)\n",
    "$$\n",
    "\n",
    "Pre-norm is more stable for deep networks."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Setup"
   ]
  },
  {
   "cell_type": "code",
<parameter name="execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 🔧 Setup\n",
    "\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print(f\"Using device: {device}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Implement the Full Mamba Block"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 🏗️ Complete Mamba Block Implementation\n",
    "\n",
    "class MambaBlock(nn.Module):\n",
    "    \"\"\"\n",
    "    Complete Mamba Block\n",
    "    \n",
    "    This implements the full Mamba architecture with:\n",
    "    - LayerNorm\n",
    "    - Input projection (expansion)\n",
    "    - SiLU gating\n",
    "    - Selective SSM\n",
    "    - Output projection (contraction)\n",
    "    - Residual connection\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(\n",
    "        self,\n",
    "        d_model: int,\n",
    "        d_state: int = 128,\n",
    "        expand_factor: int = 2,\n",
    "        dt_rank: str = 'auto',\n",
    "        bias: bool = False,\n",
    "        dropout: float = 0.0,\n",
    "    ):\n",
    "        super().__init__()\n",
    "        self.d_model = d_model\n",
    "        self.d_state = d_state\n",
    "        self.d_inner = int(expand_factor * d_model)\n",
    "        \n",
    "        if dt_rank == 'auto':\n",
    "            dt_rank = min(d_model, 16)\n",
    "        self.dt_rank = dt_rank\n",
    "        \n",
    "        # Layer normalization (pre-norm)\n",
    "        self.norm = nn.LayerNorm(d_model)\n",
    "        \n",
    "        # Input projection (expand)\n",
    "        self.in_proj = nn.Linear(d_model, self.d_inner * 2, bias=bias)\n",
    "        \n",
    "        # SSM core\n",
    "        self._init_ssm()\n",
    "        \n",
    "        # Output projection (contract)\n",
    "        self.out_proj = nn.Linear(self.d_inner, d_model, bias=bias)\n",
    "        \n",
    "        # Dropout\n",
    "        self.dropout = nn.Dropout(dropout) if dropout > 0 else None\n",
    "    \n",
    "    def _init_ssm(self):\n",
    "        \"\"\"Initialize SSM parameters\"\"\"\n",
    "        \n",
    "        # A: state dynamics (diagonal)\n",
    "        self.A_log = nn.Parameter(torch.randn(self.d_state))\n",
    "        \n",
    "        # D: skip connection\n",
    "        self.D = nn.Parameter(torch.ones(self.d_state))\n",
    "        \n",
    "        # Input to SSM parameters (Δ, B, C)\n",
    "        self.x_proj = nn.Linear(self.d_inner, self.dt_rank + self.d_state * 2, bias=False)\n",
    "        \n",
    "        # Output projection from SSM state\n",
    "        self.dt_proj = nn.Linear(self.dt_rank, self.d_inner, bias=True)\n",
    "    \n",
    "    def forward(self, x: torch.Tensor) -> torch.Tensor:\n",
    "        \"\"\"\n",
    "        Args:\n",
    "            x: (batch, seq_len, d_model)\n",
    "        Returns:\n",
    "            y: (batch, seq_len, d_model)\n",
    "        \"\"\"\n",
    "        batch, seq_len, d_model = x.shape\n",
    "        \n",
    "        # 1. Pre-norm\n",
    "        x_norm = self.norm(x)\n",
    "        \n",
    "        # 2. Input projection with split for gating\n",
    "        x_inner = self.in_proj(x_norm)  # (batch, seq_len, d_inner * 2)\n",
    "        x_inner, gate = x_inner.chunk(2, dim=-1)  # Each: (batch, seq_len, d_inner)\n",
    "        \n",
    "        # 3. Gating activation (SiLU)\n",
    "        gate = F.silu(gate)\n",
    "        \n",
    "        # 4. Selective SSM on gated input\n",
    "        ssm_out = self._ssm_forward(gate)\n",
    "        \n",
    "        # 5. Apply gate to SSM output (gated output)\n",
    "        y = ssm_out * gate\n",
    "        \n",
    "        # 6. Output projection\n",
    "        y = self.out_proj(y)\n",
    "        \n",
    "        # 7. Dropout (optional)\n",
    "        if self.dropout is not None:\n",
    "            y = self.dropout(y)\n",
    "        \n",
    "        # 8. Residual connection\n",
    "        return y + x\n",
    "    \n",
    "    def _ssm_forward(self, x: torch.Tensor) -> torch.Tensor:\n",
    "        \"\"\"\n",
    "        Forward through selective SSM.\n",
    "        \n",
    "        Args:\n",
    "            x: (batch, seq_len, d_inner)\n",
    "        Returns:\n",
    "            y: (batch, seq_len, d_inner)\n",
    "        \"\"\"\n",
    "        batch, seq_len, d_inner = x.shape\n",
    "        d_state = self.d_state\n",
    "        \n",
    "        # Compute selective parameters\n",
    "        x_params = self.x_proj(x)  # (batch, seq_len, dt_rank + 2*d_state)\n",
    "        \n",
    "        # Split into Δ, B, C\n",
    "        delta = x_params[:, :, :self.dt_rank]\n",
    "        B = x_params[:, :, self.dt_rank:self.dt_rank + d_state]\n",
    "        C = x_params[:, :, self.dt_rank + d_state:]\n",
    "        \n",
    "        # Project Δ to proper dimension\n",
    "        delta = self.dt_proj(delta)  # (batch, seq_len, d_inner)\n",
    "        \n",
    "        # Softplus for positivity\n",
    "        delta = F.softplus(delta)\n",
    "        \n",
    "        # Discretize A\n",
    "        # For efficiency, we use the inner dimension as multiple SSM channels\n",
    "        # A is (d_state,), we need to expand\n",
    "        A_bar = torch.exp(self.A_log.unsqueeze(0) * delta)  # (batch, seq_len, d_inner, d_state)\n",
    "        \n",
    "        # B discretization\n",
    "        A_log_expanded = self.A_log.unsqueeze(0).unsqueeze(0).unsqueeze(0)  # (1, 1, 1, d_state)\n",
    "        disc_factor = (A_bar - 1) / torch.where(\n",
    "            torch.abs(A_log_expanded) > 1e-6,\n",
    "            A_log_expanded,\n",
    "            1e-6\n",
    "        )\n",
    "        B_bar = disc_factor * B.unsqueeze(-1)\n",
    "        \n",
    "        # Parallel scan for each channel\n",
    "        h = selective_parallel_scan_multichan(A_bar, B_bar)\n",
    "        \n",
    "        # Output: y = C * h\n",
    "        y = torch.einsum('blnd,bln->bld', h, C)\n",
    "        \n",
    "        # Add skip connection\n",
    "        y = y + x * self.D.unsqueeze(0)\n",
    "        \n",
    "        return y\n",
    "\n",
    "\n",
    "def selective_parallel_scan_multichan(A_bar: torch.Tensor, B_bar: torch.Tensor) -> torch.Tensor:\n",
    "    \"\"\"\n",
    "    Selective parallel scan with multiple channels.\n",
    "    \n",
    "    A_bar: (batch, seq_len, channels, d_state)\n",
    "    B_bar: (batch, seq_len, channels, d_state)\n",
    "    \n",
    "    Returns: (batch, seq_len, channels, d_state)\n",
    "    \"\"\"\n",
    "    batch, seq_len, channels, d_state = A_bar.shape\n",
    "    \n",
    "    # Reshape for batched scan: (batch * channels, seq_len, d_state)\n",
    "    A = A_bar.reshape(-1, seq_len, d_state)\n",
    "    B = B_bar.reshape(-1, seq_len, d_state)\n",
    "    \n",
    "    # Pad to power of 2\n",
    "    n_padded = 1 << (seq_len - 1).bit_length()\n",
    "    \n",
    "    A_pad = torch.zeros(A.shape[0], n_padded, d_state, device=A.device, dtype=A.dtype)\n",
    "    B_pad = torch.zeros(B.shape[0], n_padded, d_state, device=B.device, dtype=B.dtype)\n",
    "    A_pad[:, :seq_len, :] = A\n",
    "    B_pad[:, :seq_len, :] = B\n",
    "    \n",
    "    # Parallel scan\n",
    "    for stride in range(n_padded.bit_length() - 1):\n",
    "        step = 1 << stride\n",
    "        \n",
    "        A_even = A_pad[:, ::step*2, :]\n",
    "        B_even = B_pad[:, ::step*2, :]\n",
    "        \n",
    "        A_odd = A_pad[:, step::step*2, :]\n",
    "        B_odd = B_pad[:, step::step*2, :]\n",
    "        \n",
    "        A_comb = A_even * A_odd\n",
    "        B_comb = A_even * B_odd + B_even\n",
    "        \n",
    "        A_pad[:, step::step*2, :] = A_comb\n",
    "        B_pad[:, step::step*2, :] = B_comb\n",
    "    \n",
    "    # Extract\n",
    "    result = B_pad[:, :seq_len, :]\n",
    "    return result.reshape(batch, channels, seq_len, d_state).transpose(1, 2)\n",
    "\n",
    "\n",
    "# Test the Mamba Block\n",
    "print(\"Testing Mamba Block...\")\n",
    "block = MambaBlock(d_model=256, d_state=128, expand_factor=2).to(device)\n",
    "x = torch.randn(2, 32, 256).to(device)\n",
    "y = block(x)\n",
    "print(f\"Input shape: {x.shape}\")\n",
    "print(f\"Output shape: {y.shape}\")\n",
    "\n",
    "# Check gradients\n",
    "loss = y.sum()\n",
    "loss.backward()\n",
    "print(\"✅ Backpropagation works!\")\n",
    "\n",
    "# Count parameters\n",
    "n_params = sum(p.numel() for p in block.parameters())\n",
    "print(f\"\\n📊 Total parameters: {n_params:,}\")"
   ]
  },
