   "source": [
    "# 📚 Build Mamba SSM from Scratch - Part 6: Benchmark & Comparison\n",
    "\n",
    "---\n",
    "\n",
    "**Colab Ready**: This notebook runs on Google Colab with GPU support!\n",
    "\n",
    "**Objectives**:\n",
    "1. Benchmark Mamba vs Transformer\n",
    "2. Compare memory usage\n",
    "3. Analyze inference speed\n",
    "4. Understand trade-offs\n",
    "\n",
    "---\n",
    "\n",
    "## 1. Overview\n",
    "\n",
    "In this notebook, we comprehensively compare Mamba with Transformers:\n",
    "\n",
    "| Metric | Transformer | Mamba |\n",
    "|--------|-------------|-------|\n",
    "| Time Complexity | O(N²) | O(N) |\n",
    "| Memory | O(N²) KV cache | O(N) state |\n",
    "| Inference | Autoregressive | Autoregressive |\n",
    "| Content Selection | Full attention | Selective state |\n",
    "| Parallel Training | Yes | Yes |\n",
    "\n",
    "---"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 🔧 Setup\n",
    "\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "import time\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print(f\"Using device: {device}\")\n",
    "if torch.cuda.is_available():\n",
    "    print(f\"GPU: {torch.cuda.get_device_name(0)}\")"
   ]
  },
  {
   "cell_type": "code",
<parameter name="execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 🧮 Mamba Implementation (Quick Copy)\n",
    "\n",
    "def selective_parallel_scan(A_bar, B_bar):\n",
    "    batch, seq_len, d_state = A_bar.shape\n",
    "    n_padded = 1 << (seq_len - 1).bit_length()\n",
    "    A = torch.zeros(batch, n_padded, d_state, device=A_bar.device, dtype=A_bar.dtype)\n",
    "    B = torch.zeros(batch, n_padded, d_state, device=B_bar.device, dtype=B_bar.dtype)\n",
    "    A[:, :seq_len, :] = A_bar\n",
    "    B[:, :seq_len, :] = B_bar\n",
    "    for stride in range(n_padded.bit_length() - 1):\n",
    "        step = 1 << stride\n",
    "        A_even = A[:, ::step*2, :]\n",
    "        B_even = B[:, ::step*2, :]\n",
    "        A_odd = A[:, step::step*2, :]\n",
    "        B_odd = B[:, step::step*2, :]\n",
    "        A[:, step::step*2, :] = A_even * A_odd\n",
    "        B[:, step::step*2, :] = A_even * B_odd + B_even\n",
    "    return B[:, :seq_len, :]\n",
    "\n",
    "\n",
    "class MambaBlock(nn.Module):\n",
    "    def __init__(self, d_model, d_state=128, expand=2):\n",
    "        super().__init__()\n",
    "        self.d_inner = int(d_model * expand)\n",
    "        self.d_state = d_state\n",
    "        self.dt_rank = min(d_model, 16)\n",
    "        self.norm = nn.LayerNorm(d_model)\n",
    "        self.in_proj = nn.Linear(d_model, self.d_inner * 2)\n",
    "        self.A_log = nn.Parameter(torch.randn(d_state))\n",
    "        self.D = nn.Parameter(torch.ones(d_state))\n",
    "        self.x_proj = nn.Linear(self.d_inner, self.dt_rank + d_state * 2, bias=False)\n",
    "        self.dt_proj = nn.Linear(self.dt_rank, self.d_inner, bias=True)\n",
    "        self.out_proj = nn.Linear(self.d_inner, d_model)\n",
    "    \n",
    "    def forward(self, x):\n",
    "        x_norm = self.norm(x)\n",
    "        x_inner, gate = self.in_proj(x_norm).chunk(2, dim=-1)\n",
    "        gate = F.silu(gate)\n",
    "        ssm_out = self._ssm(gate)\n",
    "        y = self.out_proj(ssm_out * gate)\n",
    "        return y + x\n",
    "    \n",
    "    def _ssm(self, x):\n",
    "        B, L, D = x.shape\n",
    "        N = self.d_state\n",
    "        x_params = self.x_proj(x)\n",
    "        delta = F.softplus(self.dt_proj(x_params[:, :, :self.dt_rank]))\n",
    "        B_param = x_params[:, :, self.dt_rank:self.dt_rank+N]\n",
    "        C_param = x_params[:, :, self.dt_rank+N:]\n",
    "        A_bar = torch.exp(self.A_log.unsqueeze(0) * delta)\n",
    "        disc = (A_bar - 1) / torch.where(torch.abs(self.A_log) > 1e-6, self.A_log, 1e-6)\n",
    "        B_bar = disc.unsqueeze(-1) * B_param.unsqueeze(-1)\n",
    "        h = selective_parallel_scan(A_bar, B_bar)\n",
    "        y = torch.einsum('bln,bln->bl', h, C_param)\n",
    "        return y + x * self.D\n",
    "\n",
    "\n",
    "class TransformerBlock(nn.Module):\n",
    "    def __init__(self, d_model, n_heads=8):\n",
    "        super().__init__()\n",
    "        self.norm = nn.LayerNorm(d_model)\n",
    "        self.attn = nn.MultiheadAttention(d_model, n_heads, batch_first=True)\n",
    "        self.ff = nn.Sequential(\n",
    "            nn.Linear(d_model, d_model * 4),\n",
    "            nn.GELU(),\n",
    "            nn.Linear(d_model * 4, d_model)\n",
    "        )\n",
    "    \n",
    "    def forward(self, x):\n",
    "        x = x + self.attn(self.norm(x), self.norm(x), self.norm(x))[0]\n",
    "        x = x + self.ff(self.norm(x))\n",
    "        return x\n",
    "\n",
    "\n",
    "print(\"✅ Models defined!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Forward Pass Benchmark"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title ⏱️ Forward Pass Speed\n",
    "\n",
    "seq_lens = [32, 64, 128, 256, 512, 1024, 2048]\n",
    "d_model = 256\n",
    "\n",
    "mamba_times = []\n",
    "transformer_times = []\n",
    "\n",
    "for seq_len in seq_lens:\n",
    "    mamba = MambaBlock(d_model=d_model, d_state=128).to(device)\n",
    "    transformer = TransformerBlock(d_model=d_model, n_heads=8).to(device)\n",
    "    \n",
    "    x = torch.randn(4, seq_len, d_model).to(device)\n",
    "    \n",
    "    # Warm up\n",
    "    with torch.no_grad():\n",
    "        _ = mamba(x)\n",
    "        _ = transformer(x)\n",
    "    \n",
    "    if device.type == 'cuda':\n",
    "        torch.cuda.synchronize()\n",
    "    \n",
    "    # Time Mamba\n",
    "    start = time.perf_counter()\n",
    "    with torch.no_grad():\n",
    "        for _ in range(20):\n",
    "            y_m = mamba(x)\n",
    "    if device.type == 'cuda':\n",
    "        torch.cuda.synchronize()\n",
    "    t_m = (time.perf_counter() - start) / 20 * 1000\n",
    "    mamba_times.append(t_m)\n",
    "    \n",
    "    # Time Transformer\n",
    "    start = time.perf_counter()\n",
    "    with torch.no_grad():\n",
    "        for _ in range(20):\n",
    "            y_t = transformer(x)\n",
    "    if device.type == 'cuda':\n",
    "        torch.cuda.synchronize()\n",
    "    t_t = (time.perf_counter() - start) / 20 * 1000\n",
    "    transformer_times.append(t_t)\n",
    "    \n",
    "    print(f\"Seq {seq_len:4d}: Mamba={t_m:7.2f}ms, Transformer={t_t:7.2f}ms, Speedup={t_t/t_m:.2f}x\")\n",
    "\n",
    "# Plot\n",
    "plt.figure(figsize=(10, 5))\n",
    "plt.plot(seq_lens, mamba_times, 'o-', label='Mamba', linewidth=2)\n",
    "plt.plot(seq_lens, transformer_times, 's-', label='Transformer', linewidth=2)\n",
    "plt.xlabel('Sequence Length')\n",
    "plt.ylabel('Time (ms)')\n",
    "plt.title('Forward Pass Speed Comparison')\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "plt.savefig('forward_benchmark.png', dpi=150)\n",
    "plt.show()\n",
    "\n",
    "print(\"\\n✅ Mamba shows better scaling with sequence length!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Memory Usage"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 💾 Memory Usage\n",
    "\n",
    "def get_memory_usage(model, seq_len, batch_size=4):\n",
    "    \"\"\"Get peak memory usage\"\"\"\n",
    "    if device.type == 'cuda':\n",
    "        torch.cuda.empty_cache()\n",
    "        torch.cuda.reset_peak_memory_stats()\n",
    "    \n",
    "    x = torch.randn(batch_size, seq_len, d_model).to(device)\n",
    "    \n",
    "    with torch.no_grad():\n",
    "        y = model(x)\n",
    "    \n",
    "    if device.type == 'cuda':\n",
    "        return torch.cuda.max_memory_allocated() / 1024**2  # MB\n",
    "    else:\n",
    "        return 0  # Can't easily measure on CPU\n",
    "\n",
    "mamba_memory = []\n",
    "transformer_memory = []\n",
    "\n",
    "for seq_len in seq_lens:\n",
    "    mamba = MambaBlock(d_model=d_model, d_state=128).to(device)\n",
    "    transformer = TransformerBlock(d_model=d_model, n_heads=8).to(device)\n",
    "    \n",
    "    mem_m = get_memory_usage(mamba, seq_len)\n",
    "    mem_t = get_memory_usage(transformer, seq_len)\n",
    "    \n",
    "    mamba_memory.append(mem_m)\n",
    "    transformer_memory.append(mem_t)\n",
    "    \n",
    "    print(f\"Seq {seq_len:4d}: Mamba={mem_m:7.1f}MB, Transformer={mem_t:7.1f}MB\")\n",
    "\n",
    "# Plot\n",
    "plt.figure(figsize=(10, 5))\n",
    "plt.plot(seq_lens, mamba_memory, 'o-', label='Mamba', linewidth=2)\n",
    "plt.plot(seq_lens, transformer_memory, 's-', label='Transformer', linewidth=2)\n",
    "plt.xlabel('Sequence Length')\n",
    "plt.ylabel('Memory (MB)')\n",
    "plt.title('Peak Memory Usage')\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "plt.savefig('memory_benchmark.png', dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Autoregressive Generation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 🔄 Autoregressive Generation Speed\n",
    "\n",
    "def generate_autoregressive(model, max_tokens, seq_len=512):\n",
    "    \"\"\"Generate tokens autoregressively\"\"\"\n",
    "    x = torch.zeros(1, 1, d_model).to(device)\n",
    "    \n",
    "    for _ in range(max_tokens):\n",
    "        x_cond = x[:, -seq_len:, :]\n",
    "        with torch.no_grad():\n",
    "            y = model(x_cond)\n",
    "        next_token = y[:, -1:, :]\n",
    "        x = torch.cat([x, next_token], dim=1)\n",
    "    \n",
    "    return x\n",
    "\n",
    "max_tokens_list = [32, 64, 128, 256]\n",
    "\n",
    "mamba_gen_times = []\n",
    "transformer_gen_times = []\n",
    "\n",
    "for max_tokens in max_tokens_list:\n",
    "    mamba = MambaBlock(d_model=d_model, d_state=128).to(device)\n",
    "    transformer = TransformerBlock(d_model=d_model, n_heads=8).to(device)\n",
    "    \n",
    "    # Warm up\n",
    "    with torch.no_grad():\n",
    "        _ = generate_autoregressive(mamba, 10)\n",
    "        _ = generate_autoregressive(transformer, 10)\n",
    "    \n",
    "    if device.type == 'cuda':\n",
    "        torch.cuda.synchronize()\n",
    "    \n",
    "    # Time Mamba\n",
    "    start = time.perf_counter()\n",
    "    with torch.no_grad():\n",
    "        _ = generate_autoregressive(mamba, max_tokens)\n",
    "    if device.type == 'cuda':\n",
    "        torch.cuda.synchronize()\n",
    "    t_m = (time.perf_counter() - start) * 1000\n",
    "    mamba_gen_times.append(t_m)\n",
    "    \n",
    "    # Time Transformer\n",
    "    start = time.perf_counter()\n",
    "    with torch.no_grad():\n",
    "        _ = generate_autoregressive(transformer, max_tokens)\n",
    "    if device.type == 'cuda':\n",
    "        torch.cuda.synchronize()\n",
    "    t_t = (time.perf_counter() - start) * 1000\n",
    "    transformer_gen_times.append(t_t)\n",
    "    \n",
    "    print(f\"Tokens {max_tokens:3d}: Mamba={t_m:7.2f}ms, Transformer={t_t:7.2f}ms\")\n",
    "\n",
    "# Plot\n",
    "plt.figure(figsize=(10, 5))\n",
    "plt.plot(max_tokens_list, mamba_gen_times, 'o-', label='Mamba', linewidth=2)\n",
    "plt.plot(max_tokens_list, transformer_gen_times, 's-', label='Transformer', linewidth=2)\n",
    "plt.xlabel('Tokens Generated')\n",
    "plt.ylabel('Time (ms)')\n",
    "plt.title('Autoregressive Generation Speed')\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "plt.savefig('generation_benchmark.png', dpi=150)\n",
    "plt.show()"
   ]
  },
