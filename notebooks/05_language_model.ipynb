   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 📚 Build Mamba SSM from Scratch - Part 5: Language Model\n",
    "\n",
    "---\n",
    "\n",
    "**Colab Ready**: This notebook runs on Google Colab with GPU support!\n",
    "\n",
    "**Objectives**:\n",
    "1. Build a complete character-level language model\n",
    "2. Train Mamba on real text data\n",
    "3. Generate text with the trained model\n",
    "4. Understand training dynamics\n",
    "\n",
    "---\n",
    "\n",
    "## 1. Architecture Overview\n",
    "\n",
    "A language model consists of:\n",
    "\n",
    "```\n",
    "Input Text: \"hello world\"\n",
    "    │\n",
    "    ▼\n",
    "┌─────────────────────────────┐\n",
    "│  Token Embeddings          │  vocab_size → d_model\n",
    "└─────────────────────────────┘\n",
    "    │\n",
    "    ▼\n",
    "┌─────────────────────────────┐\n",
    "│  Mamba Layers (N)          │  Stack of Mamba blocks\n",
    "└─────────────────────────────┘\n",
    "    │\n",
    "    ▼\n",
    "┌─────────────────────────────┐\n",
    "│  Language Model Head       │  d_model → vocab_size\n",
    "└─────────────────────────────┘\n",
    "    │\n",
    "    ▼\n",
    "Next Token Probabilities\n",
    "```"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Setup"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 🔧 Setup\n",
    "\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from pathlib import Path\n",
    "\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print(f\"Using device: {device}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Copy Previous Components"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 🔧 Import Mamba Components\n",
    "\n",
    "# Copy the Mamba components from previous notebook\n",
    "\n",
    "def selective_parallel_scan_multichan(A_bar: torch.Tensor, B_bar: torch.Tensor) -> torch.Tensor:\n",
    "    batch, seq_len, channels, d_state = A_bar.shape\n",
    "    A = A_bar.reshape(-1, seq_len, d_state)\n",
    "    B = B_bar.reshape(-1, seq_len, d_state)\n",
    "    \n",
    "    n_padded = 1 << (seq_len - 1).bit_length()\n",
    "    \n",
    "    A_pad = torch.zeros(A.shape[0], n_padded, d_state, device=A.device, dtype=A.dtype)\n",
    "    B_pad = torch.zeros(B.shape[0], n_padded, d_state, device=B.device, dtype=B.dtype)\n",
    "    A_pad[:, :seq_len, :] = A\n",
    "    B_pad[:, :seq_len, :] = B\n",
    "    \n",
    "    for stride in range(n_padded.bit_length() - 1):\n",
    "        step = 1 << stride\n",
    "        A_even = A_pad[:,, :]\n",
    "        ::step*2 B_even = B_pad[:, ::step*2, :]\n",
    "        A_odd = A_pad[:, step::step*2, :]\n",
    "        B_odd = B_pad[:, step::step*2, :]\n",
    "        A_comb = A_even * A_odd\n",
    "        B_comb = A_even * B_odd + B_even\n",
    "        A_pad[:, step::step*2, :] = A_comb\n",
    "        B_pad[:, step::step*2, :] = B_comb\n",
    "    \n",
    "    result = B_pad[:, :seq_len, :]\n",
    "    return result.reshape(batch, channels, seq_len, d_state).transpose(1, 2)\n",
    "\n",
    "\n",
    "class MambaBlock(nn.Module):\n",
    "    def __init__(self, d_model: int, d_state: int = 128, expand_factor: int = 2, dt_rank: str = 'auto'):\n",
    "        super().__init__()\n",
n",
    "        self.d_model = d_model\n",
    "        self.d_state = d_state\n",
    "        self.d_inner = int(expand_factor * d_model)\n",
    "        \n",
    "        if dt_rank == 'auto':\n",
    "            dt_rank = min(d_model, 16)\n",
    "        self.dt_rank = dt_rank\n",
    "        \n",
    "        self.norm = nn.LayerNorm(d_model)\n",
    "        self.in_proj = nn.Linear(d_model, self.d_inner * 2)\n",
    "        \n",
    "        self.A_log = nn.Parameter(torch.randn(self.d_state))\n",
    "        self.D = nn.Parameter(torch.ones(self.d_state))\n",
    "        self.x_proj = nn.Linear(self.d_inner, self.dt_rank + self.d_state * 2, bias=False)\n",
    "        self.dt_proj = nn.Linear(self.dt_rank, self.d_inner, bias=True)\n",
    "        self.out_proj = nn.Linear(self.d_inner, d_model)\n",
    "    \n",
    "    def forward(self, x: torch.Tensor) -> torch.Tensor:\n",
    "        batch, seq_len, d_model = x.shape\n",
    "        x_norm = self.norm(x)\n",
    "        x_inner = self.in_proj(x_norm)\n",
    "        x_inner, gate = x_inner.chunk(2, dim=-1)\n",
    "        gate = F.silu(gate)\n",
    "        ssm_out = self._ssm_forward(gate)\n",
    "        y = ssm_out * gate\n",
    "        y = self.out_proj(y)\n",
    "        return y + x\n",
    "    \n",
    "    def _ssm_forward(self, x: torch.Tensor) -> torch.Tensor:\n",
    "        batch, seq_len, d_inner = x.shape\n",
    "        d_state = self.d_state\n",
    "        \n",
    "        x_params = self.x_proj(x)\n",
    "        delta = x_params[:, :, :self.dt_rank]\n",
    "        B = x_params[:, :, self.dt_rank:self.dt_rank + d_state]\n",
    "        C = x_params[:, :, self.dt_rank + d_state:]\n",
    "        \n",
    "        delta = self.dt_proj(delta)\n",
    "        delta = F.softplus(delta)\n",
    "        \n",
    "        A_bar = torch.exp(self.A_log.unsqueeze(0) * delta)\n",
    "        A_log_expanded = self.A_log.unsqueeze(0).unsqueeze(0).unsqueeze(0)\n",
    "        disc_factor = (A_bar - 1) / torch.where(torch.abs(A_log_expanded) > 1e-6, A_log_expanded, 1e-6)\n",
    "        B_bar = disc_factor * B.unsqueeze(-1)\n",
    "        \n",
    "        h = selective_parallel_scan_multichan(A_bar, B_bar)\n",
    "        y = torch.einsum('blnd,bln->bld', h, C)\n",
    "        y = y + x * self.D.unsqueeze(0)\n",
    "        return y\n",
    "\n",
    "\n",
    "print(\"✅ Mamba components imported!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Create the Language Model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 🏗️ Mamba Language Model\n",
    "\n",
    "class MambaLM(nn.Module):\n",
    "    \"\"\"\n",
    "    Complete Mamba Language Model\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(\n",
    "        self,\n",
    "        vocab_size: int,\n",
    "        d_model: int = 256,\n",
    "        n_layers: int = 4,\n",
    "        d_state: int = 128,\n",
    "        expand_factor: int = 2,\n",
    "    ):\n",
    "        super().__init__()\n",
    "        \n",
    "        self.vocab_size = vocab_size\n",
    "        self.d_model = d_model\n",
    "        \n",
    "        # Token embeddings\n",
    "        self.embedding = nn.Embedding(vocab_size, d_model)\n",
    "        \n",
    "        # Stack of Mamba blocks\n",
    "        self.layers = nn.ModuleList([\n",
    "            MambaBlock(d_model, d_state, expand_factor)\n",
    "            for _ in range(n_layers)\n",
    "        ])\n",
    "        \n",
    "        # Output projection (language model head)\n",
    "        self.norm = nn.LayerNorm(d_model)\n",
    "        self.lm_head = nn.Linear(d_model, vocab_size, bias=False)\n",
    "        \n",
    "        # Weight tying (tie output weights with embeddings)\n",
    "        self.lm_head.weight = self.embedding.weight\n",
    "    \n",
    "    def forward(self, x: torch.Tensor, targets: torch.Tensor = None) -> torch.Tensor:\n",
    "        \"\"\"\n",
    "        Args:\n",
    "            x: (batch, seq_len) - token indices\n",
    "            targets: (batch, seq_len) - target indices (for loss computation)\n",
    "        Returns:\n",
    "            logits: (batch, seq_len, vocab_size)\n",
    "        \"\"\"\n",
    "        # Embed tokens\n",
    "        x = self.embedding(x)\n",
    "        \n",
    "        # Apply Mamba layers\n",
    "        for layer in self.layers:\n",
    "            x = layer(x)\n",
    "        \n",
    "        x = self.norm(x)\n",
    "        \n",
    "        # Project to vocabulary\n",
    "        logits = self.lm_head(x)\n",
    "        \n",
    "        # Compute loss if targets provided\n",
    "        loss = None\n",
    "        if targets is not None:\n",
    "            loss = F.cross_entropy(\n",
    "                logits.view(-1, self.vocab_size),\n",
    "                targets.view(-1),\n",
    "                ignore_index=-100\n",
    "            )\n",
    "        \n",
    "        return logits, loss\n",
    "    \n",
    "    @torch.no_grad()\n",
    "    def generate(self, x: torch.Tensor, max_new_tokens: int, temperature: float = 1.0) -> torch.Tensor:\n",
    "        \"\"\"\n",
    "        Generate tokens autoregressively.\n",
    "        \n",
    "        Args:\n",
    "            x: (batch, seq_len) - starting tokens\n",
    "            max_new_tokens: number of tokens to generate\n",
    "            temperature: sampling temperature\n",
    "        Returns:\n",
    "            generated tokens\n",
    "        \"\"\"\n",
    "        for _ in range(max_new_tokens):\n",
    "            # Crop context if needed\n",
    "            x_cond = x if x.size(1) <= 256 else x[:, -256:]\n",
    "            \n",
    "            # Forward pass\n",
    "            logits, _ = self(x_cond)\n",
    "            \n",
    "            # Get last token logits\n",
    "            logits = logits[:, -1, :] / temperature\n",
    "            \n",
    "            # Sample\n",
    "            probs = F.softmax(logits, dim=-1)\n",
    "            next_token = torch.multinomial(probs, num_samples=1)\n",
    "            \n",
    "            # Append\n",
    "            x = torch.cat([x, next_token], dim=1)\n",
    "        \n",
    "        return x\n",
    "\n",
    "\n",
    "# Create model\n",
    "model = MambaLM(vocab_size=256, d_model=256, n_layers=4, d_state=128).to(device)\n",
    "print(f\"Model parameters: {sum(p.numel() for p in model.parameters()):,}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Data Preparation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 📊 Prepare Text Data\n",
    "\n",
    "# Use a simple text corpus (Wikipedia sample)\n",
    "text = \"\"\"\n",
    "The history of natural language processing (NLP) generally started in the 1950s, although work can be found from earlier periods. \n",
    "In 1950, Alan Turing published an article titled \"Computing Machinery and Intelligence\" which proposed what is now called the Turing test as a criterion of intelligence. \n",
    "The Georgetown experiment in 1954 involved fully automatic translation of more than sixty Russian sentences into English. \n",
    "The authors claimed that within three or five years, machine translation would be a solved problem. \n",
    "However, real progress was much slower, and after the ALPAC report in 1966, which found that ten years of research had failed to fulfill expectations, funding for machine translation was dramatically reduced. \n",
    "Little further research in machine translation was conducted until the late 1980s, when the first statistical machine translation systems were developed.\n",
    "Neural networks were experimented with for language modeling in the early 1990s. \n",
    "The work on statistical language models was advanced greatly by the work of Joshua T. Guer on cache language models (1990s). \n",
    "Modern large language models are based on the Transformer architecture, introduced in 2017. \n",
    "Since then, models like GPT, BERT, and their variants have achieved state-of-the-art results on many NLP tasks.\n",
    "State Space Models (SSMs) represent an alternative to attention-based models. \n",
    "They can achieve similar performance while being more computationally efficient, especially for long sequences.\n",
    "Mamba is a recently proposed selective state space model that achieves strong performance on various tasks.\n",
    "It combines the efficiency of SSMs with the selectivity of attention mechanisms.\n",
    "The model uses a parallel scan algorithm to compute states efficiently.\n",
    "This allows it to process long sequences with linear time and memory complexity.\n",
    "Unlike transformers, Mamba does not require attention computations for each token pair.\n",
    "Instead, it maintains a hidden state that can selectively remember or forget information.\n",
    "This selective mechanism allows the model to focus on relevant context.\n",
    "The architecture consists of multiple Mamba blocks stacked together.\n",
    "Each block contains a selective state space model with gating mechanisms.\n",
    "The gating helps the model control information flow.\n",
    "Training Mamba is similar to training other neural networks.\n",
    "It uses standard backpropagation through time.\n",
    "The model can be trained on GPUs efficiently.\n",
    "Text generation is done autoregressively.\n",
    "At each step, the model predicts the next token.\n",
    "The predicted token is fed back as input.\n",
    "This process continues until a stop condition is reached.\n",
    "Language models learn statistical patterns in text.\n",
    "They capture regularities in the training data.\n",
    "Larger models can capture more complex patterns.\n",
    "They learn syntax, semantics, and even some world knowledge.\n",
    "The quality of the training data is important.\n",
    "Models can generate coherent and fluent text.\n",
    "They can be used for various downstream tasks.\n",
    "These include translation, summarization, and question answering.\n",
    "The field continues to evolve rapidly.\n",
    "New architectures and training methods are being developed.\n",
    "The goal is to create more capable and efficient models.\n",
    "Future models may have even longer context windows.\n",
    "They may better handle multimodal inputs.\n",
    "They may have improved reasoning capabilities.\n",
    "The research community continues to push boundaries.\n",
    "\"\"\"\n",
    "\n",
    "# Create character-level vocabulary\n",
    "chars = sorted(list(set(text)))\n",
    "vocab_size = len(chars)\n",
    "print(f\"Vocabulary size: {vocab_size}\")\n",
    "print(f\"Characters: {chars[:50]}...\")\n",
    "\n",
    "# Create character to index mapping\n",
    "char_to_idx = {ch: i for i, ch in enumerate(chars)}\n",
    "idx_to_char = {i: ch for i, ch in enumerate(chars)}\n",
    "\n",
    "# Encode text\n",
    "data = torch.tensor([char_to_idx[ch] for ch in text], dtype=torch.long)\n",
    "print(f\"Data size: {len(data)} tokens\")\n",
    "\n",
    "# Split into train/val\n",
    "n = int(0.9 * len(data))\n",
    "train_data = data[:n]\n",
    "val_data = data[n:]\n",
    "print(f\"Train: {len(train_data)}, Val: {len(val_data)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Training Loop"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 🏋️ Training Loop\n",
    "\n",
    "def get_batch(data: torch.Tensor, batch_size: int, seq_len: int) -> tuple:\n",
    "    \"\"\"Get random batch from data\"\"\"\n",
    "    ix = torch.randint(len(data) - seq_len, (batch_size,))\n",
    "    x = torch.stack([data[i:i+seq_len] for i in ix])\n",
    "    y = torch.stack([data[i+1:i+seq_len+1] for i in ix])\n",
    "    return x.to(device), y.to(device)\n",
    "\n",
    "\n",
    "# Training configuration\n",
    "batch_size = 32\n",
    "seq_len = 64\n",
    "learning_rate = 0.001\n",
    "max_epochs = 100\n",
    "\n",
    "# Create model\n",
    "model = MambaLM(vocab_size=vocab_size, d_model=192, n_layers=3, d_state=96).to(device)\n",
    "optimizer = torch.optim.AdamW(model.parameters(), lr=learning_rate)\n",
    "scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=max_epochs)\n",
    "\n",
    "print(f\"Model parameters: {sum(p.numel() for p in model.parameters()):,}\")\n",
    "\n",
    "# Training\n",
    "train_losses = []\n",
    "val_losses = []\n",
    "\n",
    "@torch.no_grad()\n",
    "def evaluate():\n",
    "    \"\"\"Evaluate on validation set\"\"\"\n",
    "    model.eval()\n",
    "    losses = []\n",
    "    for _ in range(10):\n",
    "        x, y = get_batch(val_data, batch_size, seq_len)\n",
    "        _, loss = model(x, y)\n",
    "        losses.append(loss.item())\n",
    "    model.train()\n",
    "    return np.mean(losses)\n",
    "\n",
    "print(\"Starting training...\")\n",
    "\n",
    "for epoch in range(max_epochs):\n",
    "    # Get batch\n",
    "    x, y = get_batch(train_data, batch_size, seq_len)\n",
    "    \n",
    "    # Forward pass\n",
    "    optimizer.zero_grad()\n",
    "    logits, loss = model(x, y)\n",
    "    \n",
    "    # Backward pass\n",
    "    loss.backward()\n",
    "    torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)\n",
    "    optimizer.step()\n",
    "    scheduler.step()\n",
    "    \n",
    "    train_losses.append(loss.item())\n",
    "    \n",
    "    # Evaluate periodically\n",
    "    if (epoch + 1) % 20 == 0:\n",
    "        val_loss = evaluate()\n",
    "        val_losses.append(val_loss)\n",
    "        print(f\"Epoch {epoch+1:3d}: train_loss={loss.item():.4f}, val_loss={val_loss:.4f}\")\n",
    "\n",
    "# Plot\n",
    "plt.figure(figsize=(10, 4))\n",
    "plt.plot(train_losses, label='Train')\n",
    "plt.plot([i*20 for i in range(len(val_losses))], val_losses, 'o-', label='Val')\n",
    "plt.xlabel('Epoch')\n",
    "plt.ylabel('Loss')\n",
    "plt.title('Training Curve')\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "plt.savefig('lm_training.png', dpi=150)\n",
    "plt.show()\n",
    "\n",
    "print(\"✅ Training complete!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Text Generation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title ✍️ Generate Text\n",
    "\n",
    "# Start with some context\n",
    "context = \"The\"\n",
    "context_idx = torch.tensor([[char_to_idx[c] for c in context]], dtype=torch.long).to(device)\n",
    "\n",
    "# Generate\n",
    "model.eval()\n",
    "with torch.no_grad():\n",
    "    generated = model.generate(context_idx, max_new_tokens=300, temperature=0.8)\n",
    "    generated_text = ''.join([idx_to_char[i.item()] for i in generated[0]])\n",
    "\n",
    "print(\"Generated text:\")\n",
    "print(\"=\" * 50)\n",
    "print(generated_text)\n",
    "print(\"=\" * 50)\n",
    "\n",
    "# Try different temperatures\n",
    "for temp in [0.5, 1.0, 1.5]:\n",
    "    context_idx = torch.tensor([[char_to_idx['T']]], dtype=torch.long).to(device)\n",
    "    with torch.no_grad():\n",
    "        generated = model.generate(context_idx, max_new_tokens=100, temperature=temp)\n",
    "        text = ''.join([idx_to_char[i.item()] for i in generated[0]])\n",
    "    print(f\"\\nTemperature {temp}:\")\n",
    "    print(text[:200])"
   ]
  },
