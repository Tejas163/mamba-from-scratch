   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Training a Selective SSM"
   ]
  },
  {
   "cell_type": "code",
<parameter name="execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 🏋️ Simple Training Demo\n",
    "\n",
    "# Let's train a selective SSM on a simple task\n",
    "\n",
    "class SimpleSSMModel(nn.Module):\n",
    "    \"\"\"Simple SSM for sequence modeling\"\"\"\n",
    "    \n",
    "    def __init__(self, vocab_size: int, d_model: int, d_state: int):\n",
    "        super().__init__()\n",
    "        self.embedding = nn.Embedding(vocab_size, d_model)\n",
    "        self.ssm = SelectiveSSM(d_model, d_state)\n",
    "        self.output = nn.Linear(d_model, vocab_size)\n",
    "    \n",
    "    def forward(self, x: torch.Tensor) -> torch.Tensor:\n",
    "        x = self.embedding(x)\n",
    "        x = self.ssm(x)\n",
    "        x = self.output(x)\n",
    "        return x\n",
    "\n",
    "\n",
    "# Create a simple task: predict next character in a sequence\n",
    "# Using a simple grammar: alternating AB pattern\n",
    "def generate_data(n_samples=1000, seq_len=20):\n",
    "    \"\"\"Generate sequences with pattern: ABABAB... or BABABA...\"\"\"\n",
    "    data = []\n",
    "    for _ in range(n_samples):\n",
    "        start = torch.randint(0, 2, (1,)).item()  # 0 or 1\n",
    "        seq = torch.arange(start, start + seq_len) % 2\n",
    "        data.append(seq)\n",
    "    return torch.stack(data)\n",
    "\n",
    "data = generate_data(1000, 20)\n",
    "print(f\"Data shape: {data.shape}\")\n",
    "print(f\"Example sequences: {data[:3]}\")\n",
    "\n",
    "# Train\n",
    "model = SimpleSSMModel(vocab_size=2, d_model=32, d_state=64).to(device)\n",
    "optimizer = torch.optim.AdamW(model.parameters(), lr=0.001)\n",
    "criterion = nn.CrossEntropyLoss()\n",
    "\n",
    "print(\"\\nTraining...\")\n",
    "losses = []\n",
    "\n",
    "for epoch in range(50):\n",
    "    total_loss = 0\n",
    "    for i in range(0, len(data) - 1, 32):\n",
    "        batch = data[i:i+32].to(device)\n",
    "        \n",
    "        # Input: all but last, Target: all but first\n",
    "        x = batch[:, :-1]\n",
    "        y = batch[:, 1:]\n",
    "        \n",
    "        optimizer.zero_grad()\n",
    "        out = model(x)\n",
    "        loss = criterion(out.reshape(-1, 2), y.reshape(-1))\n",
    "        loss.backward()\n",
    "        optimizer.step()\n",
    "        \n",
    "        total_loss += loss.item()\n",
    "    \n",
    "    losses.append(total_loss)\n",
    "    if (epoch + 1) % 10 == 0:\n",
    "        print(f\"Epoch {epoch+1}, Loss: {total_loss:.4f}\")\n",
    "\n",
    "# Plot training curve\n",
    "plt.figure(figsize=(8, 4))\n",
    "plt.plot(losses)\n",
    "plt.xlabel('Epoch')\n",
    "plt.ylabel('Loss')\n",
    "plt.title('Training Selective SSM')\n",
    "plt.grid(True)\n",
    "plt.savefig('training_curve.png', dpi=150)\n",
    "plt.show()\n",
    "\n",
    "# Test\n",
    "with torch.no_grad():\n",
    "    test_seq = data[:1, :-1].to(device)\n",
    "    pred = model(test_seq).argmax(dim=-1)\n",
    "    print(f\"\\nInput: {data[0, :-1].tolist()}\")\n",
    "    print(f\"Target: {data[0, 1:].tolist()}\")\n",
    "    print(f\"Pred:   {pred[0].tolist()}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Summary\n",
    "\n",
    "### What makes Mamba special:\n",
    "\n",
    "| Feature | Basic SSM | Selective SSM (Mamba) |\n",
    "|---------|-----------|------------------------|\n",
    "| A matrix | Fixed | Fixed |\n",
    "| B matrix | Fixed | **Input-dependent** |\n",
    "| C matrix | Fixed | **Input-dependent** |\n",
    "| Δ (step) | Fixed | **Input-dependent** |\n",
    "| Computation | Parallel | Parallel |\n",
    "| Selection | ❌ | ✅ |\n",
    "\n",
    "### Key Insights:\n",
    "\n",
    "1. **Selective parameters** allow the model to ignore irrelevant tokens\n",
    "2. **Δ selection** controls how much each token influences the state\n",
    "3. **B selection** controls how inputs are absorbed into state\n",
    "4. **C selection** controls what's extracted from state\n",
    "\n",
    "This is what gives Mamba its **content-based reasoning** ability - it can selectively attend to relevant context!\n",
    "\n",
    "---\n",
    "\n",
    "**Next**: In [Part 4](./04_mamba_block.ipynb), we'll build the **full Mamba block** with gating, normalization, and all the modern tricks!"
   ]
  }
